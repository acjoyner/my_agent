# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── Email (optional override) ─────────────────────────────────────────────────
# The agent sends email via your authorized Google account.
# Set this if you want alerts sent to a different address than your Gmail.
NOTIFY_EMAIL=you@gmail.com

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token below
# 2. Message @userinfobot to get your numeric chat ID
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNopQRsTuvWxyz
TELEGRAM_CHAT_ID=987654321
